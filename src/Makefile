# Compiler and flags
CXX      = g++
CXXFLAGS = -Wall -Wextra -std=c++17 -MMD -MP

# Sources and targets
SRCS   := main.cpp cpu.cpp debug.cpp 
OBJS   := $(SRCS:.cpp=.o)
DEPS   := $(OBJS:.o=.d)
TARGET := Atari2600

# Default target
all: $(TARGET)

# Link the main program
$(TARGET): $(OBJS)
	$(CXX) $(CXXFLAGS) -o $@ $^

# Compile any .cpp -> .o (deps autogenerated)
%.o: %.cpp
	$(CXX) $(CXXFLAGS) -c $< -o $@

# Extra executables
cpuTest: cpuTest.o cpu.o
	$(CXX) $(CXXFLAGS) -o $@ $^

test: test.o
	$(CXX) $(CXXFLAGS) -o $@ $^

# Cleanup
clean:
	rm -f $(OBJS) $(DEPS) $(TARGET) cpuTest test *.o *.d

# Include auto-generated dependency files
-include $(DEPS)

.PHONY: all clean
